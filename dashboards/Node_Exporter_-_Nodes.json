        "pluginVersion": "v11.4.0",
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "$datasource"
            },
            "expr": "(\n  (1 - sum without (mode) (rate(node_cpu_seconds_total{job=\"node-exporter\", mode=~\"idle|iowait|steal\", instance=\"$instance\", cluster=~\"kubernetes\"}[$__rate_interval])))\n/ ignoring(cpu) group_left\n  count without (cpu, mode) (node_cpu_seconds_total{job=\"node-exporter\", mode=\"idle\", instance=\"$instance\", cluster=~\"kubernetes\"})\n)\n",
            "intervalFactor": 5,
            "legendFormat": "{{cpu}}"
          }
